
<article>
{# Loop through the posts array #}
{% for post in posts %}
  <header>
    <h2 class="headline">{{post.title}}</h2>
      <p class="byline">
        <address class="author"> By <a rel="author" href="#">{{post.author}}</a></address>
        on <strong>some time<strong>
      </p> 
  </header>
  <div class="article-content"> 
        <p>{{post.body}}</p>
  </div>
{% else %}
<p>No posts found</p>
{% endfor %}
</article>
<nav>
  <a href="#">Back to top...</a>
</nav>

